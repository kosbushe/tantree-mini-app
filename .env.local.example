# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Mini App URL (public site origin — used for card preview links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Telegram bot / mini app link for "share app" buttons (e.g. https://t.me/YourBot/app)
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/YourBot/app

# Server-side mini app URL (bot web_app button, webhook)
TELEGRAM_WEBAPP_URL=https://your-app.vercel.app

# Optional: secret token passed when registering the webhook with Telegram
# TELEGRAM_WEBHOOK_SECRET=your_random_secret

# Supabase — NOT required when NEXT_PUBLIC_ALLOW_MOCK_AUTH=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Offline dev mode: uses NEXT_PUBLIC_MOCK_USER_ID when Telegram initData is absent
NEXT_PUBLIC_ALLOW_MOCK_AUTH=true
NEXT_PUBLIC_MOCK_USER_ID=123456789
